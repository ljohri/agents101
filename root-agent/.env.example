# Root planner agent environment (copy to root-agent/.env).
# The root agent runs as its own process with its own credentials, separate
# from the agent_stack runtime.

# --- HTTP(S) entrypoint -----------------------------------------------------
ROOT_AGENT_HOST=127.0.0.1
ROOT_AGENT_PORT=8443
# Provide both to serve over HTTPS; leave unset for plain HTTP (dev only).
ROOT_AGENT_TLS_CERTFILE=
ROOT_AGENT_TLS_KEYFILE=

# --- Downstream agent_stack runtime (reached over A2A) ----------------------
RUNTIME_BASE_URL=http://127.0.0.1:8086
# Bearer token forwarded to the runtime when ALLOW_DEV_NO_AUTH is off there.
RUNTIME_BEARER_TOKEN=
DISCOVERY_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=30

# --- LLM provider -----------------------------------------------------------
# One of: openai | anthropic | gemini | vertex
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Used by openai | anthropic | gemini (API-key auth).
LLM_API_KEY=
# Optional override for OpenAI-compatible endpoints.
LLM_BASE_URL=

# --- Vertex AI (Gemini via service account) ---------------------------------
# When LLM_PROVIDER=vertex, authenticate with a service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# --- Memory (Claude-style global + local) -----------------------------------
ROOT_AGENT_GLOBAL_MEMORY=~/.root-agent/memory/GLOBAL.md
ROOT_AGENT_LOCAL_MEMORY=./.root-agent/memory/LOCAL.md
ROOT_AGENT_MEMORY_MAX_CHARS=4000
ROOT_AGENT_ENABLE_SESSION_MEMORY=true

# --- Global commands (local CLI execution) ----------------------------------
ROOT_AGENT_COMMANDS_DIR=~/.root-agent/commands
ROOT_AGENT_LOCAL_COMMANDS_DIR=./.root-agent/commands
# Master switch for running local CLI utilities. Disable to forbid command.* steps.
ROOT_AGENT_ALLOW_LOCAL_COMMANDS=true
