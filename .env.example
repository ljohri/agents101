# Server
HOST=127.0.0.1
PORT=8086
ALLOW_DEV_NO_AUTH=true
ALLOW_PUBLIC_BIND=false
LOCAL_AGENT_TOKEN=change-me

# App DB
APP_DATABASE_URL=sqlite:///./data/agent.db
APP_RETENTION_MESSAGES_DAYS=90
APP_RETENTION_TOOL_CALLS_DAYS=30
APP_RETENTION_AUDIT_DAYS=365
APP_RETENTION_APPROVALS_DAYS=365

# LangGraph
USE_LANGGRAPH=false
LANGGRAPH_CHECKPOINTER=memory
LANGGRAPH_SQLITE_PATH=./data/langgraph.db
LANGGRAPH_POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/agent_runtime?sslmode=disable

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_PATH=/metrics
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_SERVICE_NAME=agent_stack
OTEL_TRACES_SAMPLER=always_on
# OTEL_TRACES_SAMPLER_ARG=

# Optional integrations
OPENCLAW_ENABLED=false
NEMOCLAW_ENABLED=false

# Outbound A2A tokens (per remote agent in agents.yaml)
# EXTERNAL_RESEARCHER_TOKEN=...

# MCP server headers (per server in mcp_servers.yaml)
# FETCH_MCP_BEARER=...
